else{listMenu.addClass("show");}});});</script></nav><div class="nav-right"><a class="item doc-nhieu" href="https://laodong.vn/ldt/doc-nhieu"> <span class="name"> Đọc nhiều </span> <span class="icon"> <i class="fa fa-line-chart" aria-hidden="true"></i> </span> </a><div class="p-search"><a ng-click="vm.searchClick()" class="item search" href="javascript:"> <span class="name"> Tìm kiếm </span> <span class="icon"> <i class="fa fa-search" aria-hidden="true"></i> </span> </a><div ng-class="vm.showSearch ? 'show' : ''" class="tim-kiem"><div class="gg-search"><gcse:search></gcse:search></div></div></div><div class="account-header"><a href="javascript:" class="item account" data-bs-toggle="modal" data-bs-target="#modal-login-ld"> <span class="name"> Đăng nhập </span> <span class="icon"> <i class="fa fa-user" aria-hidden="true"></i> </span> </a></div><script>$(document).ready(function(){var btnAccountIconHeader=$("#btn-account-icon-header")
btnAccountIconHeader.click(function(){var menuAccountHeader=$("#menu-account-header");if(menuAccountHeader.hasClass('show')){menuAccountHeader.removeClass('show');}
else{menuAccountHeader.addClass("show");}});});</script></div></div></div></div></div></header><div class="body-content"><div class="b-left m-bottom-20 m-top-20"><div class="sticky-box"></div></div><div class="b-center"><div class="wrapper page-chi-tiet-tin n2"><div class="m-bottom-10 m-top-10"><div class="lst-advs" data-key="ldt-pc-top" data-total="1"><div class="item"><zone id="k4to0lzm"></zone><script>arfAsync.push("k4to0lzm");</script></div></div></div><div ng-controller="ChiTietTinCtrl as vm" articleid="1019521" category-key="giai-tri" ga-id="UA-43649544-1"><div id="top-article" class="blk-c2-01"><div class="pl"><div class="breadcrums"><h3><a class="main-cat-lnk" href="https://laodong.vn/ldt/giai-tri"> Giải trí </a></h3><div class="children-cats"><div class="list"><h3><a class="item" href="https://laodong.vn/ldt/sao-viet"> Sao Việt </a></h3><span class="spr"> - </span><h3><a class="item" href="https://laodong.vn/ldt/gameshow"> Gameshow </a></h3><span class="spr"> - </span><h3><a class="item" href="https://laodong.vn/ldt/phim-anh"> Phim ảnh </a></h3><span class="spr"> - </span><h3><a class="item" href="https://laodong.vn/ldt/van-nghe"> Văn nghệ </a></h3></div></div></div><article class="article-detail"><div class="wrapper-01"><h1 class="title">NU&#x27;EST: Hành trình 10 năm tìm ánh hào quang</h1></div><div class="wrapper-02"><div class="art-info"><i class="fa fa-user-circle-o" aria-hidden="true"></i> <span class="authors">Phương Linh</span> &nbsp; - &nbsp; <span class="time"> Thứ tư, 02/03/2022 21:17 (GMT+7) </span></div><div class="google-news"><a href="https://news.google.com/publications/CAAqBwgKMNTlvAsw4YDUAw?hl=vi&amp;gl=VN&amp;ceid=VN%3Avi"> <img src="https://media-cdn-v2.laodong.vn/lib/images/google-news-laodongtre.png" height="28"> </a></div><div class="chappeau">Ngày 28.2, thông tin nhóm nhạc Hàn Quốc <a href="https://laodong.vn/giai-tri/nuest-nhom-nhac-kpop-tung-la-doi-thu-cua-exo-tan-ra-sau-10-nam-1018595.ldo" title="NU'EST" target="_self">NU'EST</a> tan rã gây chấn động cộng đồng fan K-pop. Cùng nhìn lại hành trình 10 năm hoạt động nhiều dấu ấn của nhóm nhạc 5 thành viên.</div><div id="gallery-ctt" class="art-body"><figure class="insert-center-image"><img src="https://media-cdn-v2.laodong.vn/storage/newsportal/2022/3/2/1019521/304-3046854_2019-Nu--01.jpg" alt="NU'EST: Hành trình 10 năm tìm ánh hào quang"></figure><p><strong>Ra mắt với bản hit “FACE”</strong><p>Ngày 15.3.2012, NU'EST gồm 5 thành viên: JR, Aron, Ren, Minhyun và Baekho ra mắt công chúng, hoạt động dưới sự quản lý của công ty giải trí Pledis Entertainment. Tên nhóm mang ý nghĩa "xây dựng một phong cách âm nhạc mới".</p><figure class="insert-center-image"><img src="https://media-cdn-v2.laodong.vn/Storage/NewsPortal/2022/3/2/1019521/Nuest.jpg" alt="NU'EST được coi là đối thủ nặng ký của EXO thuở mới ra mắt. Ảnh: Soompi."><figcaption class="image-caption">NU'EST được coi là đối thủ nặng ký của EXO thuở mới ra mắt. Ảnh: Soompi.</figcaption></figure><p>Điều này được thể hiện rõ qua bản hit đầu tay "FACE". Với phong cách mới lạ cùng nội dung nói đến bạo lực học đường, ca khúc nhanh chóng nhận được nhiều đánh giá tích cực. MV "FACE" cũng nằm trong top những MV debut của Kpop có lượt xem cao nhất.<p>Với màn ra mắt đầy ấn tượng, NU'EST được kỳ vọng là nhóm nhạc có tương lai tươi sáng, thậm chí được coi là đối thủ của nhóm nhạc tân binh cùng thời EXO.<p><strong>Đánh mất hào quang, đứng trước nguy cơ tan rã</strong><p>Không lâu sau khi ra mắt, Pledis Entertainment chuyển hướng cho NU'EST hoạt động tại thị trường quốc tế. Năm 2013, nhóm kết nạp thành viên Jason người Trung Quốc tạo thành nhóm NU’EST-M với tham vọng thâu tóm thị trường Đại lục.</p><figure class="insert-center-image"><img src="https://media-cdn-v2.laodong.vn/Storage/NewsPortal/2022/3/2/1019521/Maxresdefault2.jpg" alt="Đội hình nhóm NU'EST-M với thành viên Jason. Ảnh: AS-MUSIC."><figcaption class="image-caption">Đội hình nhóm NU'EST-M với thành viên Jason. Ảnh: AS-MUSIC.</figcaption></figure><p>Trái với dự kiến, kế hoạch hoàn toàn thất bại. Năm 2014, Jason rời NU’EST. Tạm biệt thị trường Trung Quốc, NU’EST tới Nhật Bản. Tuy sở hữu được một lượng fan nhất định nhưng danh tiếng nhóm ở quê nhà đã giảm sút nặng nề.<p>Chiến lược đưa một nhóm nhạc mới nổi như NU’EST tiến ra thị trường quốc tế khi chưa xây dựng vị trí vững chắc tại Hàn Quốc bị nhiều fan đánh giá là thiếu khôn ngoan.<p>4 năm kể từ khi ra mắt, nhóm cho ra nhiều sản phẩm âm nhạc khác song không đạt được thành tích nổi bật. Mức độ nổi tiếng ngày một giảm, số lượng album bán ra ít dần, NU'EST đứng trước nguy cơ tan rã.<p><strong>Cú lội ngược dòng ngoạn mục</strong><p>Năm 2017, NU'EST tham gia chương trình “Produce 101 mùa 2”. Sự xuất hiện của một nhóm tại show sống còn dành cho thực tập sinh ngay lập tức thu hút sự chú ý của công chúng.</p><figure class="insert-center-image"><img src="https://media-cdn-v2.laodong.vn/Storage/NewsPortal/2022/3/2/1019521/Nuest-Produce-101-2.png" alt="4/5 thành viên NU'EST tham gia “Produce 101 mùa 2“. Ảnh: AllKpop."><figcaption class="image-caption">4/5 thành viên NU'EST tham gia “Produce 101 mùa 2“. Ảnh: AllKpop.</figcaption></figure><p>Xuyên suốt chương trình, NU’EST đã chứng minh được thực lực của bản thân. Tuy nhiên, tới cuối cùng chỉ có Minhyun thành công ra mắt với nhóm nhạc Wanna One. Theo điều khoản đã thỏa thuận, Minhyun sẽ không hoạt động với NU’EST cho tới khi Wanna One tan rã.<p>Hậu “Produce 101 mùa 2”, NU’EST trở thành cái tên gây chú ý. Hàng loạt album, ca khúc của nhóm “lội ngược dòng” các bảng xếp hạng. Nhóm cũng thu về một lượng fan lớn.<p>Cuối năm 2017, NU'EST tái xuất với đội hình 4 thành viên, hoạt động dưới cái tên NU’EST W. Suốt 2 năm tiếp theo, nhóm thu về loạt thành tích đáng nể. Đặc biệt, mini-album "W,HERE" đã biến NU’EST W trở thành một trong những nhóm nhạc unit có lượng album bán chạy nhất.<p><strong>NU’EST hồi sinh</strong><p>Năm 2019, sau khi kết thúc hợp đồng với Wanna One, Minhyun trở về nhóm, NU’EST chính thức trở lại. Bài hát kỷ niệm 7 năm thành lập nhóm "A Song For You" nhanh chóng đứng đầu các bảng xếp hạng âm nhạc Hàn Quốc và bảng xếp hạng iTunes tại nhiều khu vực.</p><figure class="insert-center-image"><img src="https://media-cdn-v2.laodong.vn/Storage/NewsPortal/2022/3/2/1019521/304-3046854_2019-Nu-.jpg" alt="NU'EST trở lại với đội hình 5 thành viên vào năm 2019, gặt hái được nhiều thành công. Ảnh: Dispatch."><figcaption class="image-caption">NU'EST trở lại với đội hình 5 thành viên vào năm 2019, gặt hái được nhiều thành công. Ảnh: Dispatch.</figcaption></figure><p>Cuối tháng 4, nhóm cho ra mắt mini album "Happily Ever After" với ca khúc chủ đề "Bet Bet". Đây cũng là ca khúc đem tới chiếc cúp đầu tiên của NU’EST sau 7 năm hoạt động. Trong thời gian tiếp theo, NU’EST liên tục cho ra các sản phẩm âm nhạc mới, nhận được sự hưởng ứng từ đông đảo người hâm mộ.<p><strong>Tan rã đột ngột</strong><p>Chiều 28.2, Pledis Entertainment cho biết hợp đồng nghệ sĩ độc quyền với NU'EST sẽ kết thúc vào ngày 14.3 tới. Ba thành viên JR, Aron và Ren quyết định rời công ty. Riêng hai nam thần tượng Baekho và Minhyun tiếp tục gia hạn hợp đồng.<p>Công ty cũng tiết lộ album cuối cùng của nhóm sẽ được phát hành vào tháng 3. Sau đó, các thành viên sẽ kết thúc hoạt động chính thức với tư cách là NU'EST trực thuộc Pledis Entertainment.</p><figure class="insert-center-image"><img src="https://media-cdn-v2.laodong.vn/Storage/NewsPortal/2022/3/2/1019521/Nuest_Members_Romant.jpg" alt="Tin nhóm tan rã được công bố trước thềm kỷ niệm 10 năm hoạt động khiến nhiều fan ngỡ ngàng. Ảnh: K-Pop Database."><figcaption class="image-caption">Tin nhóm tan rã được công bố trước thềm kỷ niệm 10 năm hoạt động khiến nhiều fan ngỡ ngàng. Ảnh: K-Pop Database.</figcaption></figure><p>Thông tin được công bố ngay trước thềm kỷ niệm 10 năm hoạt động đã gây chấn động cộng đồng fan. Bên cạnh tiếc nuối, hụt hẫng, nhiều fan cho biết sẽ tiếp tục ủng hộ các thành viên trên con đường mà họ đã chọn.</div><div class="m-bottom-20"></div><div class="art-footer"><div class="lst-tags"><i class="fa fa-tags" aria-hidden="true"></i><div class="content"><a href="/tags/nhom-nhac-han-quoc-182872.ldo">nhóm nhạc Hàn Quốc</a> <a href="/tags/han-quoc-237512.ldo">Hàn Quốc</a> <a href="/tags/nuest-262297.ldo">NU&#x27;EST</a> <a href="/tags/nuest-tan-ra-389695.ldo">NU&#x27;EST tan rã</a> <a href="/tags/nhom-nhac-nuest-390240.ldo">Nhóm nhạc NU&#x27;EST</a></div></div><ul class="lst-share"><li class="item"><a class="shr shr-facebook" href="javascript:" ng-click="vm.shareFacebook('https://laodong.vn/ldt/giai-tri/nuest-hanh-trinh-10-nam-tim-anh-hao-quang-1019521.ldo')"> <i class="fa fa-facebook" aria-hidden="true"></i> </a><li class="item"><a class="shr shr-twitter" href="javascript:" ng-click="vm.shareTwitter('https://laodong.vn/ldt/giai-tri/nuest-hanh-trinh-10-nam-tim-anh-hao-quang-1019521.ldo')"> <i class="fa fa-twitter" aria-hidden="true"></i> </a><li class="item"><a class="shr shr-mail" href="mailto:toasoan@laodong.com.vn"> <i class="fa fa-envelope" aria-hidden="true"></i> </a><li class="item"><a class="shr go-top" href="#top-article" target="_self"> <i class="fa fa-arrow-circle-up" aria-hidden="true"></i> </a></ul></div><div class="tin-lien-quan"><div class="item"><i class="fa fa-stop" aria-hidden="true"></i> <a class="title" href="https://laodong.vn/ldt/phim-anh/phim-han-dong-mau-dac-canh-goc-khuat-chong-toi-pham-1019411.ldo"> Phim Hàn &quot;Dòng máu đặc cảnh&quot;: Góc khuất chống tội phạm </a></div><div class="item"><i class="fa fa-stop" aria-hidden="true"></i> <a class="title" href="https://laodong.vn/ldt/phim-anh/dien-vien-thu-vai-giao-su-x-xac-nhan-se-co-mat-trong-doctor-strange-2-1019339.ldo"> Diễn viên thủ vai Giáo sư X xác nhận sẽ có mặt trong Doctor Strange 2 </a></div><div class="item"><i class="fa fa-stop" aria-hidden="true"></i> <a class="title" href="https://laodong.vn/ldt/giai-tri/bxh-album-ban-chay-nhat-toan-cau-nam-2021-bts-seventeen-xep-thu-may-1019152.ldo"> BXH album bán chạy nhất toàn cầu năm 2021: BTS, SEVENTEEN xếp thứ mấy? </a></div></div><div class="box-binh-luan"><div class="form-binh-luan vs"><div class="head-name">Bình luận:</div><div class="form-group"><div class="form-control vs-noi-dung">Bạn nghĩ gì về nội dung này?</div></div><div class="f-cmd"><div class="vs-note">Bạn cần đăng nhập để gửi bình luận.</div><span type="button" class="btn btn btn-primarybld btn-sm"> Gửi bình luận </span></div></div></div></div></article><div class="m-bottom-20"><div class="lst-advs" data-key="ldt-pc-article-bottom" data-total="2"><div class="item"><zone id="jo8e3l18"></zone><script>arfAsync.push("jo8e3l18");</script></div></div></div><div class="blk-cung-chuyen-muc"><div class="vinhet-01"><span>Cùng chuyên mục</span></div><div class="p-lst-articles"><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/dan-truong-xac-nhan-bay-tu-my-ve-viet-nam-de-tham-gia-show-cua-a-tuan-1666345.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/9/1666345/Dan-Truong.jpg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Đan Trường xác nhận bay từ Mỹ về Việt Nam để tham gia show của A Tuân" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/dan-truong-xac-nhan-bay-tu-my-ve-viet-nam-de-tham-gia-show-cua-a-tuan-1666345.ldo"><h2 class="title prefix-icon">Đan Trường xác nhận bay từ Mỹ về Việt Nam để tham gia show của A Tuân</h2></a><div class="info"><span class="time"> 09/03/2026 16:10 </span></div><div class="chapeau">Đan Trường bay từ Mỹ về Việt Nam để tham gia đại nhạc hội “Việt Nam tinh hoa - Anh em bốn bể một nhà” do ca nhạc sĩ A Tuân tổ chức vào 28.4.</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/dan-sao-hollywood-hoi-tu-trong-phim-bom-tan-co-dau-1665982.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/8/1665982/Image2-Large.jpeg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Dàn sao Hollywood hội tụ trong phim bom tấn “Cô dâu!”" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/dan-sao-hollywood-hoi-tu-trong-phim-bom-tan-co-dau-1665982.ldo"><h2 class="title prefix-icon">Dàn sao Hollywood hội tụ trong phim bom tấn “Cô dâu!”</h2></a><div class="info"><span class="time"> 09/03/2026 07:30 </span></div><div class="chapeau">Lấy cảm hứng từ câu chuyện kinh điển về Frankenstein, phim “Cô dâu!” quy tụ dàn diễn viên thực lực của Hollywood như Jessie Buckley, Christian Bale...</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/nghe-si-thanh-ngoc-tung-tu-ti-bo-lo-co-hoi-1665978.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/8/1665978/HEM-KHONG-TINH-YEU-2.jpeg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Nghệ sĩ Thanh Ngọc từng tự ti, bỏ lỡ cơ hội" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/nghe-si-thanh-ngoc-tung-tu-ti-bo-lo-co-hoi-1665978.ldo"><h2 class="title prefix-icon">Nghệ sĩ Thanh Ngọc từng tự ti, bỏ lỡ cơ hội</h2></a><div class="info"><span class="time"> 08/03/2026 23:37 </span></div><div class="chapeau">Nghệ sĩ Thanh Ngọc từng tự ti, bỏ lỡ cơ hội, được chị gái Thanh Hằng và Ngân Quỳnh động viên.</div></div></article><div class="m-bottom-20"></div><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/quan-quan-bien-thuy-cung-thanh-thuy-bao-ngoc-lan-toa-ao-dai-viet-1665680.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/8/1665680/_LB_9866-Large-01.jpeg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Quán quân Biện Thuy cùng Thanh Thủy, Bảo Ngọc lan tỏa áo dài Việt" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/quan-quan-bien-thuy-cung-thanh-thuy-bao-ngoc-lan-toa-ao-dai-viet-1665680.ldo"><h2 class="title prefix-icon">Quán quân Biện Thuy cùng Thanh Thủy, Bảo Ngọc lan tỏa áo dài Việt</h2></a><div class="info"><span class="time"> 08/03/2026 11:35 </span></div><div class="chapeau">Quán quân Biện Thuy, Hoa hậu Thanh Thủy, Bảo Ngọc và các đại sứ Lễ hội Áo dài Thành phố Hồ Chí Minh năm 2026 cùng lan tỏa tình yêu áo dài Việt.</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/hoa-hau-bao-ngoc-nsnd-trinh-kim-chi-dien-ao-dai-gam-lua-cua-viet-hung-1665484.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/7/1665484/Kim-Chi00.jpg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Hoa hậu Bảo Ngọc, NSND Trịnh Kim Chi diễn áo dài gấm lụa của Việt Hùng" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/hoa-hau-bao-ngoc-nsnd-trinh-kim-chi-dien-ao-dai-gam-lua-cua-viet-hung-1665484.ldo"><h2 class="title prefix-icon">Hoa hậu Bảo Ngọc, NSND Trịnh Kim Chi diễn áo dài gấm lụa của Việt Hùng</h2></a><div class="info"><span class="time"> 07/03/2026 19:27 </span></div><div class="chapeau">Lê Nguyễn Bảo Ngọc , NSND Trịnh Kim Chi diễn áo dài gấm lụa của nhà thiết kế Việt Hùng trong khuôn khổ Lễ hội Áo dài TPHCM lần thứ 12 năm 2026.</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/dao-dien-le-thanh-son-tro-lai-cau-lac-bo-tram-ti-voi-bau-vat-troi-cho-1665502.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/7/1665502/DU__2687-Large.jpeg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Đạo diễn Lê Thanh Sơn trở lại câu lạc bộ trăm tỉ với “Báu vật trời cho”" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/dao-dien-le-thanh-son-tro-lai-cau-lac-bo-tram-ti-voi-bau-vat-troi-cho-1665502.ldo"><h2 class="title prefix-icon">Đạo diễn Lê Thanh Sơn trở lại câu lạc bộ trăm tỉ với “Báu vật trời cho”</h2></a><div class="info"><span class="time"> 07/03/2026 19:19 </span></div><div class="chapeau">Việc phim &quot;Báu vật trời cho&quot; chính thức vượt mốc 100 tỉ đồng giúp đạo diễn Lê Thanh Sơn quay trở lại “câu lạc bộ trăm tỉ”.</div></div></article><div class="m-bottom-20"></div><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/dien-vien-sy-toan-phai-cap-cuu-tai-phim-truong-khi-quay-phim-tai-1665456.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/7/1665456/Sy-Toan.jpg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Diễn viên Sỹ Toàn phải cấp cứu tại phim trường khi quay phim “Tài”" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/dien-vien-sy-toan-phai-cap-cuu-tai-phim-truong-khi-quay-phim-tai-1665456.ldo"><h2 class="title prefix-icon">Diễn viên Sỹ Toàn phải cấp cứu tại phim trường khi quay phim “Tài”</h2></a><div class="info"><span class="time"> 07/03/2026 16:23 </span></div><div class="chapeau">Phim Tài vừa công bố tập hậu trường thứ hai, đáng chú ý, diễn viên Sỹ Toàn từng phải cấp cứu ngay tại phim trường sau khi bị tụt huyết áp khi ghi hình.</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/kha-nhu-he-lo-hau-truong-cua-phim-quy-nhap-trang-2-1665448.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/7/1665448/NIN00281-Large.jpeg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Khả Như hé lộ hậu trường của phim Quỷ nhập tràng 2" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/kha-nhu-he-lo-hau-truong-cua-phim-quy-nhap-trang-2-1665448.ldo"><h2 class="title prefix-icon">Khả Như hé lộ hậu trường của phim Quỷ nhập tràng 2</h2></a><div class="info"><span class="time"> 07/03/2026 15:55 </span></div><div class="chapeau">Phim Quỷ nhập tràng 2 tiếp tục tung video hậu trường (BTS) với nhiều khoảnh khắc đáng chú ý của dàn diễn viên, bao gồm Khả Như .</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/minh-hang-hop-tac-cung-toc-tien-lap-ky-luc-vpop-1665368.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/7/1665368/DSC_1898_2-Large.jpeg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Minh Hằng hợp tác cùng Tóc Tiên lập kỷ lục Vpop" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/minh-hang-hop-tac-cung-toc-tien-lap-ky-luc-vpop-1665368.ldo"><h2 class="title prefix-icon">Minh Hằng hợp tác cùng Tóc Tiên lập kỷ lục Vpop</h2></a><div class="info"><span class="time"> 07/03/2026 13:00 </span></div><div class="chapeau">Trở lại đường đua Vpop đầu năm 2026, Minh Hằng gây chú ý khi hợp tác cùng Tóc Tiên trong MV “Hoa hồng ai vun trồng”.</div></div></article><div class="m-bottom-20"></div><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/phim-gianh-9-de-cu-oscar-can-nha-ky-uc-cong-chieu-tai-viet-nam-1665120.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/6/1665120/Phim.jpg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Phim giành 9 đề cử Oscar “Căn nhà ký ức” công chiếu tại Việt Nam" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/phim-gianh-9-de-cu-oscar-can-nha-ky-uc-cong-chieu-tai-viet-nam-1665120.ldo"><h2 class="title prefix-icon">Phim giành 9 đề cử Oscar “Căn nhà ký ức” công chiếu tại Việt Nam</h2></a><div class="info"><span class="time"> 06/03/2026 20:38 </span></div><div class="chapeau">Bộ phim Căn nhà ký ức (tựa gốc: Sentimental Value) giành 9 đề cử Oscar vừa chính thức giới thiệu poster và trailer đến khán giả Việt Nam trước thềm ra rạp.</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/phong-ve-thang-3-soi-dong-voi-loat-phim-viet-hollywood-va-concert-k-pop-1664762.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/6/1664762/Phim-Viet.jpg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="Phòng vé tháng 3 sôi động với loạt phim Việt, Hollywood và concert K-pop" width="300" height="186"></figure></a></div><div class="pr"><a class="link-title" href="https://laodong.vn/ldt/giai-tri/phong-ve-thang-3-soi-dong-voi-loat-phim-viet-hollywood-va-concert-k-pop-1664762.ldo"><h2 class="title prefix-icon">Phòng vé tháng 3 sôi động với loạt phim Việt, Hollywood và concert K-pop</h2></a><div class="info"><span class="time"> 06/03/2026 14:13 </span></div><div class="chapeau">Tháng 3 đánh dấu sự bùng nổ của phòng vé Việt khi hàng loạt tác phẩm thuộc nhiều thể loại đồng loạt ra rạp.</div></div></article><article class="v4 p2c m002"><div class="pl"><a class="link-img" href="https://laodong.vn/ldt/giai-tri/soobin-hoa-minzy-nhan-de-cu-nghe-si-cua-nam-tai-giai-cong-hien-2026-1664558.ldo"><figure class="_thumb"><img data-src="https://media-cdn-v2.laodong.vn/storage/newsportal/2026/3/5/1664558/Hoa-Minzy-Soobin.jpg?w=300&amp;h=186&amp;crop=auto&amp;scale=both" class="lazyload img-art" alt="SOOBIN, Hòa Minzy nhận đề cử nghệ sĩ 